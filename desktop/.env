# URL da API do Backend
# Altere o IP para o endereço do servidor onde o backend está rodando
# 
# Exemplos:
# - Máquina local: http://localhost:8000
# - Rede local (IP fixo): http://192.168.1.100:8000
# - Rede local (nome da máquina): http://MEU-SERVIDOR:8000
# - Rede L2L (túnel): http://10.1.1.151:8000
#
API_URL=http://10.1.1.151:8000

# Timeout para requisições (segundos)
TIMEOUT=30

# Modo de debug (True/False)
DEBUG=False

# Versão do sistema
VERSION=1.0.0
